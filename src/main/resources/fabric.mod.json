{
  "schemaVersion": 1,
  "id": "antiafk",
  "version": "${version}",
  "name": "AntiAFK",
  "description": "A mod that prevents you from being kicked for being AFK.",
  "authors": ["potat"],
  "contact": {},
  "license": "All-Rights-Reserved",
  "icon": "assets/antiafk/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "me.Potat.antiafk.client.AntiafkClient"
    ],
    "main": [
      "me.Potat.antiafk.Antiafk"
    ]
  },
  "mixins": [
    "antiafk.mixins.json",
    {
      "config": "antiafk.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}
